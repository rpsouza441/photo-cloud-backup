# Source directory with the original gallery files.
SOURCE_DIR=/path/to/nextcloud/gallery

# Rclone remote name and destination base folder.
# Example:
# RCLONE_REMOTE=myremote
# RCLONE_REMOTE_BASE=media-archive
RCLONE_REMOTE=your_remote_name
RCLONE_REMOTE_BASE=your_destination_base

# Destination category names in the remote.
PHOTO_FOLDER=JPG
VIDEO_FOLDER=VIDEO

# Layout:
# - year_flat:  <base>/<category>/<year>/file.ext
# - year_relative: <base>/<category>/<year>/path/from/source/file.ext
DESTINATION_LAYOUT=year_flat

# How to extract the year:
# - mtime: use filesystem modification time
# - exif_or_mtime: try exiftool first, fallback to mtime
YEAR_SOURCE=mtime

# Extensions checked by the classifier.
PHOTO_EXTENSIONS=jpg,jpeg,png,webp,heic,heif,dng,nef,cr2,arw,raf,orf,rw2,tif,tiff
VIDEO_EXTENSIONS=mp4,mov,m4v,avi,mkv,3gp,webm,mts,m2ts

# Extra rclone flags appended to each copy command.
RCLONE_EXTRA_ARGS=--ignore-existing --transfers 4 --checkers 8
